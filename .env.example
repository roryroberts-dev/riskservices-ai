# BuildMySite — Environment Variables
# These are set automatically by the wizard, or manually in Vercel Dashboard > Settings > Environment Variables

# AI Provider (set by wizard)
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=your-ai-api-key

# GitHub (set by wizard)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=owner/repo-name
GITHUB_BRANCH=main

# Contact Form (set by wizard)
CONTACT_EMAIL=your@email.com
RESEND_API_KEY=your-resend-api-key

# Admin Panel (set by wizard)
ADMIN_TOKEN=a-random-secret-token

# Vercel Blob (for image storage)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
